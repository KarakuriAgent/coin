# Server
HOST=localhost
PORT=3000

# Security (optional - unset means no API key required)
API_KEY=

# Discord OAuth2 (only needed for WebUI)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback

# Session
SESSION_SECRET=change-me-in-production

# Database
DATABASE_PATH=./data/coin.db
